# ─── Base de Datos PostgreSQL ─────────────────────────────────
# Opción A: connection string completo
DATABASE_URL=postgres://usuario:password@localhost:5432/nombre_db

# Opción B: variables separadas (alternativa a DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=usuario
# PGPASSWORD=password
# PGDATABASE=nombre_db

# ─── IA — Ollama (opcional, habilita respuestas conceptuales) ─
# Asegúrate de que Ollama esté corriendo: ollama serve
# Descarga el modelo: ollama pull qwen2.5:3b-instruct
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b-instruct

# ─── Empresa ──────────────────────────────────────────────────
# ID de empresa para filtrar datos multi-empresa (default: 1)
EMPRESA_ID=1

# ─── Sesiones ─────────────────────────────────────────────────
SESSION_SECRET=cambia_esto_por_una_clave_segura_aleatoria

# ─── Puerto del servidor (default: 8080) ─────────────────────
PORT=8080
